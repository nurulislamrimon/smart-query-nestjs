{
  "name": "smart-query-nestjs",
  "version": "3.0.2",
  "type": "module",
  "description": "High-performance search, filtering, pagination, and sorting for NestJS REST APIs",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nestjs",
    "query",
    "filter",
    "search",
    "pagination",
    "sort",
    "rest-api",
    "orm-agnostic"
  ],
  "author": "Nurul Islam Rimon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nurulislamrimon/smart-query-nestjs.git"
  },
  "bugs": {
    "url": "https://github.com/nurulislamrimon/smart-query-nestjs/issues"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "qs": "^6.13.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@types/qs": "^6.9.17",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0 || ^10.0.0 || ^9.0.0",
    "@nestjs/core": "^11.0.0 || ^10.0.0 || ^9.0.0",
    "reflect-metadata": "^0.2.0 || ^0.1.13"
  }
}
