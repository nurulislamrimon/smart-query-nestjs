{
  "name": "smart-query-nestjs",
  "version": "2.0.0",
  "description": "High-performance search, filtering, pagination, and sorting for NestJS REST APIs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nestjs",
    "query",
    "filter",
    "search",
    "pagination",
    "sort",
    "rest-api",
    "orm-agnostic"
  ],
  "author": "Nurul Islam Rimon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nurulislamrimon/smart-query-nestjs.git"
  },
  "bugs": {
    "url": "https://github.com/nurulislamrimon/smart-query-nestjs/issues"
  },
  "dependencies": {
    "qs": "^6.12.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@types/qs": "^6.9.14",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^9.0.0 || ^8.0.0",
    "@nestjs/core": "^10.0.0 || ^9.0.0 || ^8.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0"
  }
}
